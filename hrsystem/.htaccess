# 文字コード
AddDefaultCharset UTF-8

# index.php 優先（ポータル認証のあと index.html）
DirectoryIndex index.php index.html

# config.php への直接アクセスを拒否
<Files "config.php">
  Require all denied
</Files>

# kintone_webhook.php は外部POST（kintone）からのアクセスを許可
<Files "kintone_webhook.php">
  Require all granted
</Files>

# キャッシュ無効（HTML・JS）
<FilesMatch "\.(html|js)$">
  Header set Cache-Control "no-store, no-cache, must-revalidate"
  Header set Pragma "no-cache"
</FilesMatch>

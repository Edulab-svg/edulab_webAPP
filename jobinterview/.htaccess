Options -Indexes
DirectoryIndex index.php index.html

# アップロードディレクトリのPHP実行を禁止（セキュリティ）
<Files ~ "\.php$">
    <IfModule mod_rewrite.c>
        RewriteEngine Off
    </IfModule>
</Files>

# SPA用：存在しないパスは index.php 経由（ポータル認証）
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteBase /jobinterview/
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} !^/jobinterview/api/
    RewriteRule ^ index.php [L]
</IfModule>

Options -Indexes
DirectoryIndex index.php index.html

# api/ 以外はすべて index.php 経由（ポータル認証）
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteRule ^api/ - [L]
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteRule ^ index.php [L]
</IfModule>

# config.php への直接アクセスを禁止
<Files "config.php">
  Require all denied
</Files>

Options -Indexes

# --- API へのルーティング ---
RewriteEngine On

# /api/ 以下はそのまま通す
RewriteRule ^api/ - [L]

# それ以外はすべて index.html へ
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^ index.html [L]

# --- PHP 設定 ---
php_value default_charset "UTF-8"
php_flag  display_errors  Off

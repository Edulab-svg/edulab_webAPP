# ============================================================
# リスティング広告 集計ダッシュボード - URL設定
# ============================================================

# 文字コード
AddDefaultCharset UTF-8

# PHP設定（Xserver対応）
<IfModule mod_php.c>
    php_value default_charset UTF-8
    php_value mbstring.internal_encoding UTF-8
</IfModule>

# キャッシュ無効化（API）
<IfModule mod_headers.c>
    <FilesMatch "\.php$">
        Header set Cache-Control "no-store, no-cache, must-revalidate"
        Header set Pragma "no-cache"
    </FilesMatch>
</IfModule>

# index.html をデフォルトに
DirectoryIndex index.html

# セキュリティ: config.phpへの直接アクセス禁止
<Files "config.php">
    Require all denied
</Files>

# .htaccess自体へのアクセス禁止
<Files ".htaccess">
    Require all denied
</Files>
